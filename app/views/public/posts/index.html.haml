.container
  .row
    .col-lg-12.col-md-10
      .tabs.d-flex.justify-content-between.align-items-center
        %ul.nav.nav-tabs
          %li.nav-item
            %a.nav-link.active(data-toggle="tab" href="#timeline") フォロー中
          %li.nav-item
            %a.nav-link(data-toggle="tab" href="#all") おすすめ
      .tab-content
        #timeline.tab-pane.fade.show.active.tl
          = render 'public/posts/index', posts: @follow_posts
        #all.tab-pane.fade.al
          = render 'public/posts/index', posts: @post_like_ranks
        = paginate @posts
      = render 'public/posts/post_button', post: @post